{
  "model": "3325B",
  "manufacturer": "HP",
  "category": "Synthesizer / Function Generator",
  "description": "HP 3325B synthesizer/function generator (1 uHz to 21 MHz). The later model in the 3325 family, adding enhanced phase resolution, an external-reference/high-stability option, improved amplitude and modulation (AM/PM) features, and an enhancements mode (ENH) over the earlier 3325A. The 3325B supports the full HP 3325A two-letter program-code command set plus additional four-letter mnemonics; this definition documents the shared two-letter command set.",
  "source": "3325B-OM.pdf",
  "aliases": ["3325B", "HP3325B"],
  "termination": { "write": "\n", "read": "\n" },
  "identity": {
    "command": "ID?",
    "matchRegex": "3325B",
    "description": "Short model identify (3325B). IDN? returns the long form."
  },
  "statusModel": {
    "srqSupported": true,
    "serialPoll": { "clearsRqs": true },
    "enableMask": { "setCommand": "ESTB {mask}", "clearCommand": "ESTB 0", "maskFormat": "decimal" },
    "doneSupport": { "supported": false },
    "errorBit": "fail",
    "bits": {
      "error": 1,
      "stop": 2,
      "start": 4,
      "fail": 8,
      "rqs": 64
    },
    "operations": {
      "sweepComplete": { "arm": "RSW;SS;", "expectBit": "stop" }
    }
  },
  "commands": [
    {
      "name": "frequency",
      "mnemonic": "FR",
      "category": "Frequency",
      "description": "Sets or queries the output frequency. Interrogate with 'FR?' (or 'IFR').",
      "set": "FR <value> <unit>",
      "query": "FR?",
      "parameters": [
        { "name": "frequency", "units": [ { "token": "HZ", "unit": "Hz" }, { "token": "KH", "unit": "kHz" }, { "token": "MH", "unit": "MHz" } ], "range": "1 uHz to 21 MHz (sine); function dependent" }
      ],
      "examples": ["FR 1 MH", "FR 10000 HZ", "FR?"]
    },
    {
      "name": "function",
      "mnemonic": "FU",
      "category": "Waveform",
      "description": "Selects the output function: 0=DC only, 1=sine, 2=square, 3=triangle, 4=positive ramp, 5=negative ramp.",
      "set": "FU<code>",
      "query": "FU?",
      "parameters": [ { "name": "function", "range": "0-5" } ],
      "examples": ["FU1", "FU2", "FU?"]
    },
    {
      "name": "amplitude",
      "mnemonic": "AM",
      "category": "Amplitude",
      "description": "Sets or queries the output amplitude.",
      "set": "AM <value> <unit>",
      "query": "AM?",
      "parameters": [
        { "name": "amplitude", "units": [{ "token": "VO", "unit": "Vpp" }, { "token": "MV", "unit": "mVpp" }, { "token": "VR", "unit": "Vrms" }, { "token": "MR", "unit": "mVrms" }, { "token": "DB", "unit": "dBm" }], "description": "VO=Vpp, MV=mVpp, VR=Vrms, MR=mVrms, DB=dBm" }
      ],
      "examples": ["AM 1.2 VO", "AM 0 DB", "AM?"]
    },
    {
      "name": "dc_offset",
      "mnemonic": "OF",
      "category": "Amplitude",
      "description": "Sets or queries the DC offset voltage.",
      "set": "OF <value> <unit>",
      "query": "OF?",
      "parameters": [ { "name": "offset", "units": [{ "token": "VO", "unit": "V" }, { "token": "MV", "unit": "mV" }] } ],
      "examples": ["OF 1 VO", "OF?"]
    },
    {
      "name": "phase",
      "mnemonic": "PH",
      "category": "Phase",
      "description": "Sets or queries the phase of the output signal.",
      "set": "PH <value> DE",
      "query": "PH?",
      "parameters": [ { "name": "phase", "units": [ { "token": "DE", "unit": "deg" } ], "description": "DE = degrees" } ],
      "examples": ["PH 90 DE", "PH?"]
    },
    {
      "name": "assign_zero_phase",
      "mnemonic": "AP",
      "category": "Phase",
      "description": "Assigns the current phase as the zero-phase reference.",
      "set": "AP",
      "examples": ["AP"]
    },
    {
      "name": "amplitude_calibration",
      "mnemonic": "AC",
      "category": "System",
      "description": "Performs an amplitude calibration cycle.",
      "set": "AC",
      "examples": ["AC"]
    },
    {
      "name": "sweep_start_frequency",
      "mnemonic": "ST",
      "category": "Sweep",
      "description": "Sets or queries the sweep start frequency.",
      "set": "ST <value> <unit>",
      "query": "ST?",
      "parameters": [ { "name": "frequency", "units": [ { "token": "HZ", "unit": "Hz" }, { "token": "KH", "unit": "kHz" }, { "token": "MH", "unit": "MHz" } ] } ],
      "examples": ["ST 1 KH", "ST?"]
    },
    {
      "name": "sweep_stop_frequency",
      "mnemonic": "SP",
      "category": "Sweep",
      "description": "Sets or queries the sweep stop frequency.",
      "set": "SP <value> <unit>",
      "query": "SP?",
      "parameters": [ { "name": "frequency", "units": [ { "token": "HZ", "unit": "Hz" }, { "token": "KH", "unit": "kHz" }, { "token": "MH", "unit": "MHz" } ] } ],
      "examples": ["SP 10 MH", "SP?"]
    },
    {
      "name": "sweep_time",
      "mnemonic": "TI",
      "category": "Sweep",
      "description": "Sets or queries the sweep time.",
      "set": "TI <value> SE",
      "query": "TI?",
      "parameters": [ { "name": "time", "units": [ { "token": "SE", "unit": "s" }, { "token": "MS", "unit": "ms" } ], "description": "SE = seconds" } ],
      "examples": ["TI 1 SE", "TI?"]
    },
    {
      "name": "start_single_sweep",
      "mnemonic": "SS",
      "category": "Sweep",
      "description": "Resets or starts a single sweep.",
      "set": "SS",
      "examples": ["SS"]
    },
    {
      "name": "start_continuous_sweep",
      "mnemonic": "SC",
      "category": "Sweep",
      "description": "Starts a continuous sweep.",
      "set": "SC",
      "examples": ["SC"]
    },
    {
      "name": "reset",
      "mnemonic": "RST",
      "category": "System",
      "description": "Resets the instrument to its preset state.",
      "set": "RST",
      "examples": ["RST"]
    },
    {
      "name": "self_test",
      "mnemonic": "TE",
      "category": "System",
      "description": "Initiates the instrument self test.",
      "set": "TE",
      "examples": ["TE"]
    },
    {
      "name": "error_query",
      "mnemonic": "ERR?",
      "category": "Status",
      "description": "Queries the error register (3-digit form). IER returns a 1-digit form.",
      "query": "ERR?",
      "examples": ["ERR?"]
    },
    {
      "name": "option_query",
      "mnemonic": "OPT?",
      "category": "System",
      "description": "Queries installed options.",
      "query": "OPT?",
      "examples": ["OPT?"]
    }
  ]
}
